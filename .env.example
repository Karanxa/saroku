# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google Vertex AI ──────────────────────────────────────
# Your Google Cloud project ID for Vertex AI
# Service account: saroku-runner@<your-project>.iam.gserviceaccount.com
VERTEX_PROJECT=saroku
VERTEX_LOCATION=us-central1
# Path to service account key (default: credentials/vertex_ai_key.json)
GOOGLE_APPLICATION_CREDENTIALS=credentials/vertex_ai_key.json
